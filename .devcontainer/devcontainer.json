{
  "name": "Pymail Dev Environment",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "dev",

  // Override the default CMD so the container stays alive for interactive dev
  "overrideCommand": true,

  "forwardPorts": [
    8501,
    8025
  ],
  "portsAttributes": {
    "8501": { "label": "Streamlit App", "onAutoForward": "notify" },
    "8025": { "label": "Mailpit Web UI", "onAutoForward": "notify" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  // Re-install deps from the mounted volume so edits to requirements.txt take effect
  "postCreateCommand": "pip install --user --no-cache-dir -r requirements.txt"
}
